# cerber.ihatebot.com — Caddy snippet (firebat edge). The live copy lives in
# /etc/caddy/Caddyfile (root-owned, assembled with the other vhosts); this is the
# version-controlled source for the cerber block.
#
# Zero-downtime: two blue-green backends (cerber-a :18080 / cerber-b :18082, see
# deploy/docker-compose.yml). Caddy load-balances both with ACTIVE health checks
# and routes to whichever is healthy — `make deploy` just starts the idle colour
# and stops the active one; Caddy follows, no reload needed.
#
# Behaviour preserved from the original vhost:
#   - CF Flexible: identical content on :80 and :443, no HTTPS redirect.
#   - Origin allow-list: Cloudflare edge + home LAN/WG only.
#   - LAN/WG clients get the shared bearer injected (keyless); public clients must
#     send their own Authorization (cerber validates it).
#   - flush_interval -1 for SSE streaming.
# $CERBER_BEARER comes from /etc/default/caddy (not committed).

(cerber) {
	import noleak
	@cerber_blocked not remote_ip 127.0.0.1 192.168.0.0/16 10.10.10.0/30 172.16.0.0/12 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29
	respond @cerber_blocked 403

	# LAN/WG: inject the shared key (keyless UX). Blue-green pool + health checks.
	@cerber_lan remote_ip 127.0.0.1 192.168.0.0/16 10.10.10.0/30
	handle @cerber_lan {
		reverse_proxy 127.0.0.1:18080 127.0.0.1:18082 {
			lb_policy first
			lb_retries 2
			lb_try_duration 5s
			fail_duration 15s
			health_uri /healthz
			health_interval 3s
			health_timeout 2s
			flush_interval -1
			header_up Authorization "Bearer {$CERBER_BEARER}"
		}
	}
	# Public (Cloudflare): forward the client's own Authorization unchanged.
	handle {
		reverse_proxy 127.0.0.1:18080 127.0.0.1:18082 {
			lb_policy first
			lb_retries 2
			lb_try_duration 5s
			fail_duration 15s
			health_uri /healthz
			health_interval 3s
			health_timeout 2s
			flush_interval -1
		}
	}
}

http://cerber.ihatebot.com {
	import acme
	import cerber
}
https://cerber.ihatebot.com {
	tls /etc/letsencrypt/live/cerber.ihatebot.com/fullchain.pem /etc/letsencrypt/live/cerber.ihatebot.com/privkey.pem
	import cerber
}
